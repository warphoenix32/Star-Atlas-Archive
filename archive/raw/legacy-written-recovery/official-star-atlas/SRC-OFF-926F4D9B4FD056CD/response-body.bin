											 data-image-width='800'
											 data-image-height='800'
										>
											<div class='imageInner' style='padding-bottom: 100%'>
												<picture>
													<source data-srcset="https://lh6.googleusercontent.com/TPZyz-p3VahknfwEWLC5m1WE3XmcJ6f4cJ4Prz_j9UNNCjKP4qy6nWjVkfFd4iDgYSM=w862 862w, https://lh6.googleusercontent.com/TPZyz-p3VahknfwEWLC5m1WE3XmcJ6f4cJ4Prz_j9UNNCjKP4qy6nWjVkfFd4iDgYSM=w1724 3068w"
															type="image/webp">
													<source data-srcset="https://lh6.googleusercontent.com/TPZyz-p3VahknfwEWLC5m1WE3XmcJ6f4cJ4Prz_j9UNNCjKP4qy6nWjVkfFd4iDgYSM=w862 862w, https://lh6.googleusercontent.com/TPZyz-p3VahknfwEWLC5m1WE3XmcJ6f4cJ4Prz_j9UNNCjKP4qy6nWjVkfFd4iDgYSM=w1724 3068w"
															type="image/jpg">
													<img data-src="https://lh6.googleusercontent.com/TPZyz-p3VahknfwEWLC5m1WE3XmcJ6f4cJ4Prz_j9UNNCjKP4qy6nWjVkfFd4iDgYSM=w862 862w, https://lh6.googleusercontent.com/TPZyz-p3VahknfwEWLC5m1WE3XmcJ6f4cJ4Prz_j9UNNCjKP4qy6nWjVkfFd4iDgYSM=w1724 3068w"
